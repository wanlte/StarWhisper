{
  "questions": [
    {
      "id": 1,
      "text": "周末你最想怎么过？",
      "options": [
        { "key": "A", "text": "户外冒险，去没去过的地方", "weights": { "adventure": 10, "thought": 2, "social": 4, "rest": 0 } },
        { "key": "B", "text": "安静看本书或研究感兴趣的东西", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 6 } },
        { "key": "C", "text": "约朋友聚会或参加活动", "weights": { "adventure": 4, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "在家舒服地待着，享受独处时光", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 2,
      "text": "遇到困难你通常会？",
      "options": [
        { "key": "A", "text": "直接冲，干就完了", "weights": { "adventure": 10, "thought": 0, "social": 2, "rest": 0 } },
        { "key": "B", "text": "冷静分析各种可能的方案", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 4 } },
        { "key": "C", "text": "找朋友或同事商量", "weights": { "adventure": 2, "thought": 2, "social": 10, "rest": 0 } },
        { "key": "D", "text": "等等看，时机到了自然能解决", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 3,
      "text": "你更喜欢哪种颜色？",
      "options": [
        { "key": "A", "text": "热烈的红色或橙色", "weights": { "adventure": 10, "thought": 0, "social": 5, "rest": 0 } },
        { "key": "B", "text": "深邃的蓝色或紫色", "weights": { "adventure": 2, "thought": 10, "social": 0, "rest": 4 } },
        { "key": "C", "text": "温暖的黄色或粉色", "weights": { "adventure": 4, "thought": 0, "social": 10, "rest": 2 } },
        { "key": "D", "text": "沉稳的绿色或灰色", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 4,
      "text": "哪种描述最像你？",
      "options": [
        { "key": "A", "text": "行动派——想到就做，不喜欢等待", "weights": { "adventure": 10, "thought": 0, "social": 2, "rest": 0 } },
        { "key": "B", "text": "思考者——喜欢分析和深入理解", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 3 } },
        { "key": "C", "text": "社交达人——和人相处让我充电", "weights": { "adventure": 3, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "倾听者——安静陪伴也是一种力量", "weights": { "adventure": 0, "thought": 3, "social": 3, "rest": 10 } }
      ]
    },
    {
      "id": 5,
      "text": "你最看重什么？",
      "options": [
        { "key": "A", "text": "自由——不被束缚做想做的事", "weights": { "adventure": 10, "thought": 4, "social": 0, "rest": 0 } },
        { "key": "B", "text": "成就——实现目标获得认可", "weights": { "adventure": 2, "thought": 8, "social": 0, "rest": 4 } },
        { "key": "C", "text": "关系——和家人朋友的紧密连接", "weights": { "adventure": 0, "thought": 0, "social": 10, "rest": 4 } },
        { "key": "D", "text": "安全——稳定的生活和内心安宁", "weights": { "adventure": 0, "thought": 3, "social": 2, "rest": 10 } }
      ]
    },
    {
      "id": 6,
      "text": "你理想中的一天？",
      "options": [
        { "key": "A", "text": "充满刺激和惊喜", "weights": { "adventure": 10, "thought": 0, "social": 4, "rest": 0 } },
        { "key": "B", "text": "学到新东西，有收获感", "weights": { "adventure": 1, "thought": 10, "social": 0, "rest": 3 } },
        { "key": "C", "text": "被朋友需要，和大家在一起", "weights": { "adventure": 3, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "平静舒适，没有压力", "weights": { "adventure": 0, "thought": 2, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 7,
      "text": "面对刚认识的人，你通常会？",
      "options": [
        { "key": "A", "text": "主动介绍自己，打开话匣子", "weights": { "adventure": 8, "thought": 0, "social": 8, "rest": 0 } },
        { "key": "B", "text": "先观察对方，判断该怎么沟通", "weights": { "adventure": 0, "thought": 8, "social": 2, "rest": 6 } },
        { "key": "C", "text": "找共同话题，迅速拉近距离", "weights": { "adventure": 2, "thought": 4, "social": 10, "rest": 0 } },
        { "key": "D", "text": "微笑回应，保持舒适的距离", "weights": { "adventure": 0, "thought": 0, "social": 4, "rest": 8 } }
      ]
    },
    {
      "id": 8,
      "text": "哪种工作环境最适合你？",
      "options": [
        { "key": "A", "text": "快节奏、结果导向，每天不一样", "weights": { "adventure": 10, "thought": 0, "social": 2, "rest": 0 } },
        { "key": "B", "text": "安静独立的空间，深度钻研", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 6 } },
        { "key": "C", "text": "团队紧密协作、氛围活跃", "weights": { "adventure": 2, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "稳定有序、压力可控的节奏", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 9,
      "text": "面对重要决定时，你更相信？",
      "options": [
        { "key": "A", "text": "直觉——第一感觉往往是对的", "weights": { "adventure": 10, "thought": 0, "social": 2, "rest": 0 } },
        { "key": "B", "text": "数据——充分分析和推演再决定", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 2 } },
        { "key": "C", "text": "朋友——听听身边人的看法", "weights": { "adventure": 0, "thought": 2, "social": 10, "rest": 0 } },
        { "key": "D", "text": "时间——让子弹飞一会儿", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 10,
      "text": "哪种情况会让你最不安？",
      "options": [
        { "key": "A", "text": "被限制自由，不能随心所欲", "weights": { "adventure": 10, "thought": 0, "social": 2, "rest": 0 } },
        { "key": "B", "text": "在不了解的领域被迫做决定", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 4 } },
        { "key": "C", "text": "长时间没有社交和互动", "weights": { "adventure": 2, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "计划被打乱，充满不确定性", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 11,
      "text": "和亲近的人发生争执，你通常会？",
      "options": [
        { "key": "A", "text": "先冷静一下，出去走走再回来聊", "weights": { "adventure": 6, "thought": 4, "social": 0, "rest": 2 } },
        { "key": "B", "text": "坐下来理性分析，把事情说清楚", "weights": { "adventure": 0, "thought": 10, "social": 4, "rest": 2 } },
        { "key": "C", "text": "主动破冰，不想让矛盾过夜", "weights": { "adventure": 2, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "给彼此空间，等情绪自然消退", "weights": { "adventure": 0, "thought": 2, "social": 2, "rest": 10 } }
      ]
    },
    {
      "id": 12,
      "text": "睡觉前你通常在想什么？",
      "options": [
        { "key": "A", "text": "明天的冒险和计划，兴奋到失眠", "weights": { "adventure": 10, "thought": 3, "social": 2, "rest": 0 } },
        { "key": "B", "text": "回顾今天的对话，反复琢磨细节", "weights": { "adventure": 0, "thought": 10, "social": 3, "rest": 2 } },
        { "key": "C", "text": "刷社交媒体看朋友们的动态", "weights": { "adventure": 2, "thought": 0, "social": 10, "rest": 2 } },
        { "key": "D", "text": "放空自己，什么都不想", "weights": { "adventure": 0, "thought": 2, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 13,
      "text": "你更享受哪种旅行的节奏？",
      "options": [
        { "key": "A", "text": "跳岛式探险，行程排满刺激的活动", "weights": { "adventure": 10, "thought": 0, "social": 3, "rest": 0 } },
        { "key": "B", "text": "沉浸式体验，花一整天泡博物馆和书店", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 5 } },
        { "key": "C", "text": "和朋友一起，去哪不重要重要的是人", "weights": { "adventure": 3, "thought": 0, "social": 10, "rest": 2 } },
        { "key": "D", "text": "找一个安静漂亮的地方彻底放松", "weights": { "adventure": 0, "thought": 3, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 14,
      "text": "什么方式最能帮你恢复精力？",
      "options": [
        { "key": "A", "text": "运动——跑步、爬山或去健身房", "weights": { "adventure": 10, "thought": 0, "social": 2, "rest": 0 } },
        { "key": "B", "text": "独处——阅读、写作或研究感兴趣的事", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 6 } },
        { "key": "C", "text": "社交——和朋友吃饭聊天打打闹闹", "weights": { "adventure": 2, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "宅家——泡个澡看剧什么都不操心", "weights": { "adventure": 0, "thought": 2, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 15,
      "text": "如果要送朋友生日礼物，你会选？",
      "options": [
        { "key": "A", "text": "一次共同的冒险体验——比如跳伞课", "weights": { "adventure": 10, "thought": 0, "social": 5, "rest": 0 } },
        { "key": "B", "text": "一本精心挑选的、对方会喜欢的书", "weights": { "adventure": 0, "thought": 10, "social": 2, "rest": 2 } },
        { "key": "C", "text": "策划一个惊喜派对", "weights": { "adventure": 3, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "实用又有品质的生活好物", "weights": { "adventure": 0, "thought": 2, "social": 2, "rest": 8 } }
      ]
    },
    {
      "id": 16,
      "text": "突然接到一个完全超出预期的任务，你？",
      "options": [
        { "key": "A", "text": "兴奋——未知才有趣，立刻开始试", "weights": { "adventure": 10, "thought": 2, "social": 0, "rest": 0 } },
        { "key": "B", "text": "先查资料做研究，搞清楚再动手", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 4 } },
        { "key": "C", "text": "拉个群把大家叫上一起商量", "weights": { "adventure": 2, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "缓缓——让我消化一下这个信息", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 17,
      "text": "哪种学习方式对你最有效？",
      "options": [
        { "key": "A", "text": "动手实践——边做边学最直接", "weights": { "adventure": 10, "thought": 2, "social": 0, "rest": 0 } },
        { "key": "B", "text": "系统学习——看教材、做笔记、画脑图", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 3 } },
        { "key": "C", "text": "小组讨论——和同学交流碰撞", "weights": { "adventure": 2, "thought": 3, "social": 10, "rest": 0 } },
        { "key": "D", "text": "反复练习——直到肌肉记忆形成", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 8 } }
      ]
    },
    {
      "id": 18,
      "text": "你挑选朋友最看重什么？",
      "options": [
        { "key": "A", "text": "有趣——能一起疯一起探索世界", "weights": { "adventure": 10, "thought": 0, "social": 4, "rest": 0 } },
        { "key": "B", "text": "深度——能进行有营养的对话", "weights": { "adventure": 0, "thought": 10, "social": 4, "rest": 2 } },
        { "key": "C", "text": "默契——一个眼神就懂彼此", "weights": { "adventure": 2, "thought": 2, "social": 10, "rest": 2 } },
        { "key": "D", "text": "靠谱——需要的时候总在", "weights": { "adventure": 0, "thought": 2, "social": 4, "rest": 10 } }
      ]
    },
    {
      "id": 19,
      "text": "同事在公开场合表扬了你，你会？",
      "options": [
        { "key": "A", "text": "大方接受，跟大家分享团队的努力", "weights": { "adventure": 5, "thought": 0, "social": 8, "rest": 0 } },
        { "key": "B", "text": "分析自己为什么做得好，以便复制", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 2 } },
        { "key": "C", "text": "很开心，当场感谢并回应大家", "weights": { "adventure": 2, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "微笑点头，不太习惯成为焦点", "weights": { "adventure": 0, "thought": 2, "social": 2, "rest": 8 } }
      ]
    },
    {
      "id": 20,
      "text": "说到「规律生活」，你第一时间想到什么？",
      "options": [
        { "key": "A", "text": "无聊——按部就班多没意思", "weights": { "adventure": 10, "thought": 0, "social": 2, "rest": 0 } },
        { "key": "B", "text": "效率——好的系统能让人更自由", "weights": { "adventure": 2, "thought": 8, "social": 0, "rest": 4 } },
        { "key": "C", "text": "约定——规律意味着和人有固定的相处", "weights": { "adventure": 0, "thought": 0, "social": 8, "rest": 4 } },
        { "key": "D", "text": "安心——固定的节奏让人踏实", "weights": { "adventure": 0, "thought": 2, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 21,
      "text": "做什么事会让你有最大的成就感？",
      "options": [
        { "key": "A", "text": "完成一项极限挑战或冒险", "weights": { "adventure": 10, "thought": 0, "social": 4, "rest": 0 } },
        { "key": "B", "text": "解决了一个别人解不了的难题", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 2 } },
        { "key": "C", "text": "帮朋友渡过难关，对方真心感谢你", "weights": { "adventure": 0, "thought": 0, "social": 10, "rest": 4 } },
        { "key": "D", "text": "把生活打理得井井有条，岁月静好", "weights": { "adventure": 0, "thought": 2, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 22,
      "text": "有人当面批评你的某个决定，你通常会？",
      "options": [
        { "key": "A", "text": "直接回怼——我的选择我做主", "weights": { "adventure": 8, "thought": 0, "social": 2, "rest": 0 } },
        { "key": "B", "text": "让对方展开说，看是否有道理", "weights": { "adventure": 0, "thought": 10, "social": 2, "rest": 4 } },
        { "key": "C", "text": "有些尴尬，换个话题缓和气氛", "weights": { "adventure": 0, "thought": 0, "social": 10, "rest": 2 } },
        { "key": "D", "text": "表面不在意，回去默默消化", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 23,
      "text": "你最有创意的想法通常来自？",
      "options": [
        { "key": "A", "text": "在户外运动或旅行途中突然灵光一闪", "weights": { "adventure": 10, "thought": 4, "social": 0, "rest": 0 } },
        { "key": "B", "text": "深夜独处，深度思考后的顿悟", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 5 } },
        { "key": "C", "text": "和朋友聊天碰撞时迸发的火花", "weights": { "adventure": 2, "thought": 4, "social": 10, "rest": 0 } },
        { "key": "D", "text": "泡澡、散步等放松状态的出神时刻", "weights": { "adventure": 2, "thought": 3, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 24,
      "text": "什么最容易让你失眠？",
      "options": [
        { "key": "A", "text": "明天有重要活动，肾上腺素提前上线", "weights": { "adventure": 8, "thought": 0, "social": 4, "rest": 0 } },
        { "key": "B", "text": "脑子里停不下来的思考和推演", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 2 } },
        { "key": "C", "text": "和朋友聊得太嗨，情绪一时收不住", "weights": { "adventure": 3, "thought": 0, "social": 10, "rest": 0 } },
        { "key": "D", "text": "担心的太多——明天、下周、明年的事一起涌来", "weights": { "adventure": 0, "thought": 4, "social": 0, "rest": 8 } }
      ]
    },
    {
      "id": 25,
      "text": "你心中最理想的度假方式是？",
      "options": [
        { "key": "A", "text": "徒步穿越无人区，征服一座山头", "weights": { "adventure": 10, "thought": 2, "social": 0, "rest": 0 } },
        { "key": "B", "text": "在古城小巷慢走，读当地历史看建筑", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 5 } },
        { "key": "C", "text": "叫上三五好友去海边，吃喝玩乐一起嗨", "weights": { "adventure": 4, "thought": 0, "social": 10, "rest": 4 } },
        { "key": "D", "text": "找一个温泉民宿，泡汤喝茶什么也不做", "weights": { "adventure": 0, "thought": 3, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 26,
      "text": "你想要养成一个新习惯，通常怎么做？",
      "options": [
        { "key": "A", "text": "立刻开始，用热情驱动自己", "weights": { "adventure": 10, "thought": 0, "social": 0, "rest": 0 } },
        { "key": "B", "text": "研究最佳方法，制定详细计划再执行", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 4 } },
        { "key": "C", "text": "拉一个人一起，互相监督打卡", "weights": { "adventure": 2, "thought": 0, "social": 10, "rest": 3 } },
        { "key": "D", "text": "从小目标开始，融入日常节奏", "weights": { "adventure": 0, "thought": 2, "social": 0, "rest": 10 } }
      ]
    },
    {
      "id": 27,
      "text": "第一次见到一个人，你最先注意到什么？",
      "options": [
        { "key": "A", "text": "气场——对方有没有感染力", "weights": { "adventure": 6, "thought": 0, "social": 6, "rest": 0 } },
        { "key": "B", "text": "谈吐——说话的逻辑和内容深度", "weights": { "adventure": 0, "thought": 10, "social": 2, "rest": 0 } },
        { "key": "C", "text": "态度——对方是否友善和开放", "weights": { "adventure": 0, "thought": 0, "social": 10, "rest": 2 } },
        { "key": "D", "text": "氛围——相处是否舒适不尴尬", "weights": { "adventure": 0, "thought": 2, "social": 4, "rest": 8 } }
      ]
    },
    {
      "id": 28,
      "text": "当一段空闲时间没有安排时，你倾向于？",
      "options": [
        { "key": "A", "text": "临时找点刺激的事做，空白太浪费了", "weights": { "adventure": 10, "thought": 0, "social": 3, "rest": 0 } },
        { "key": "B", "text": "学点东西——正好有时间看那个收藏已久的教程", "weights": { "adventure": 0, "thought": 10, "social": 0, "rest": 4 } },
        { "key": "C", "text": "看看谁有空约出来喝一杯", "weights": { "adventure": 2, "thought": 0, "social": 10, "rest": 0 } },
