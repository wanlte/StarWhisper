  "tabBar": {
    "color": "#999999",
    "selectedColor": "#D4A574",
    "backgroundColor": "#1a1a2e",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "星座",
        "iconPath": "/static/icons/tab-zodiac.png",
        "selectedIconPath": "/static/icons/tab-zodiac-active.png"
      },
      {
        "pagePath": "pages/character/character",
        "text": "角色匹配",
        "iconPath": "/static/icons/tab-character.png",
        "selectedIconPath": "/static/icons/tab-character-active.png"
      },
      {
        "pagePath": "pages/mypage/mypage",
        "text": "我的",
        "iconPath": "/static/icons/tab-my.png",
        "selectedIconPath": "/static/icons/tab-my-active.png"
      }
    ]
  },
  "globalStyle": {
    "navigationBarBackgroundColor": "#1a1a2e",
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "星语小馆",
    "backgroundColor": "#0f0f23",
    "backgroundTextStyle": "light"
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^c-(.*)": "@/components/c-$1/c-$1.vue"
    }
  }
