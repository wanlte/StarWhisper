{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "星语小馆",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/detail/detail",
      "style": {
        "navigationBarTitleText": "星座详情",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/match/match",
      "style": {
        "navigationBarTitleText": "星座配对",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/character/character",
      "style": {
        "navigationBarTitleText": "角色匹配",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/result/result",
      "style": {
        "navigationBarTitleText": "匹配结果",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/mypage/mypage",
      "style": {
        "navigationBarTitleText": "个人中心",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    }
